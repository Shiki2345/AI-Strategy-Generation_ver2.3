{
  "skill_metadata": {
    "skill_id": "amazon_approval_access_form_v2",
    "skill_name": "Amazon 页面访问控制配置（表单版）",
    "version": "2.0.0",
    "category": "访问控制",
    "tags": ["访问策略", "表单填写", "Amazon", "URL屏蔽", "审批制", "黑名单"],
    "author": "Amazon Access Policy Assistant",
    "created_at": "2024-01-15",
    "updated_at": "2026-04-13",
    "description": "针对 Amazon Seller Central / 买家账号页面生成可直接填入平台表单的访问策略输出",
    "output_target": "平台「新增访问策略」表单"
  },

  "platform_capability": {
    "description": "继承主skill的平台能力边界定义",
    "reference": "../体验内容/access_policy_skill_package/skill_definition.json → platform_capability",
    "key_constraint": "平台的审批能力仅限两个选项：仅boss可审批 / 不允许申请访问。v1.0中的多级审批链、自定义审批表单、临时权限有效期等功能超出平台能力，不再输出。"
  },

  "applicable_scenarios": [
    {
      "scene": "高敏感页面完全屏蔽",
      "description": "禁止访问结账、支付、账户设置等高风险页面",
      "keywords": ["禁止", "屏蔽", "不允许", "锁账号", "下单"],
      "form_mapping": {
        "访问审批限制": "勾选'不允许申请访问'",
        "tab": "指定网页生效策略"
      },
      "example": "禁止进入买家号checkout → 完全屏蔽，不允许申请"
    },
    {
      "scene": "敏感页面需BOSS审批",
      "description": "访问账户详情、财务报告等需BOSS审批放行",
      "keywords": ["审批", "批准", "BOSS同意", "申请访问"],
      "form_mapping": {
        "访问审批限制": "勾选'仅boss账号可审批'",
        "tab": "指定网页生效策略"
      },
      "example": "运营访问账户详情页需要BOSS审批 → boss审批制"
    },
    {
      "scene": "浏览器行为限制",
      "description": "在账号环境内限制复制、下载、查看密码等行为",
      "keywords": ["不能复制", "禁止下载", "看不了密码", "禁用F12"],
      "form_mapping": {
        "tab": "所有网页通用策略"
      },
      "example": "禁止在账号里查看密码明文 → 查看密码框设为'限制'"
    }
  ],

  "dialogue_flow": {
    "phase_1_check_and_identify": {
      "description": "识别目标页面，通过RAG检索URL，并判断平台能力",
      "steps": [
        "1. 提取用户描述中的页面关键词",
        "2. 调用RAG系统检索精确URL",
        "3. 判断需求是否在平台能力范围内",
        "4. 如果超出平台能力（如数据行级过滤），告知用户并终止",
        "5. 确认策略类型：完全屏蔽 or BOSS审批"
      ],
      "rag_integration": {
        "search_trigger": "用户提到具体页面名称时",
        "search_query_extraction": [
          "提取页面关键词",
          "识别站点信息（美国站、日本站等）",
          "识别功能类别（账户、订单、广告等）"
        ],
        "result_handling": {
          "high_similarity": ">= 0.8 直接确认URL",
          "medium_similarity": "0.5-0.8 列出候选项让用户选",
          "low_similarity": "< 0.5 请用户提供截图或输入URL"
        }
      },
      "decision_tree": {
        "完全禁止": {
          "keywords": ["禁止", "屏蔽", "不允许", "拦截", "不能进"],
          "form_action": "勾选'不允许申请访问' + 勾选'仅boss账号可审批'"
        },
        "需要审批": {
          "keywords": ["审批", "批准", "申请", "BOSS同意"],
          "form_action": "勾选'仅boss账号可审批'，不勾选'不允许申请访问'"
        }
      },
      "next_phase": "phase_2_collect_params"
    },

    "phase_2_collect_params": {
      "description": "收集表单所需参数",
      "required_fields": [
        {
          "field_name": "target_urls",
          "maps_to_form": "tab_指定网页生效策略",
          "source": "RAG检索结果 或 用户直接提供",
          "verification": "如URL来自RAG推断，标注验证状态，建议用户截图确认"
        },
        {
          "field_name": "effective_members",
          "maps_to_form": "生效成员",
          "question": "对哪些人生效？",
          "default": "除BOSS外所有成员"
        },
        {
          "field_name": "effective_accounts",
          "maps_to_form": "生效平台账号",
          "question": "对哪些平台账号生效？",
          "default": "所有账号"
        },
        {
          "field_name": "effective_period",
          "maps_to_form": "生效时段",
          "question": "什么时候生效？",
          "common_choices": {
            "全天全周": "all_day_everyday preset",
            "仅工作时间": "standard_workday preset",
            "下班后": "after_work preset"
          }
        },
        {
          "field_name": "browser_controls",
          "maps_to_form": "tab_所有网页通用策略",
          "default_preset": "account_security（限制密码框，其余允许且记录）",
          "note": "涉及登录账号的策略，建议默认限制查看密码框"
        }
      ],
      "next_phase": "phase_3_confirm"
    },

    "phase_3_confirm": {
      "description": "确认配置，检查约束",
      "checks": [
        "策略名称 ≤ 24字符",
        "策略描述 ≤ 400字符",
        "URL验证状态标注",
        "域名精准度确认（如 qq.com → v.qq.com）"
      ],
      "next_phase": "phase_4_generate_form_output"
    },

    "phase_4_generate_form_output": {
      "description": "生成表单填写版输出",
      "output_structure": {
        "form_output": {
          "策略名称": "≤24字符",
          "生效成员": "平台选项值",
          "生效平台账号": "平台选项值",
          "生效时段": {"生效日期": {}, "生效周期": {}, "生效时间": {}},
          "访问策略描述": "≤400字符",
          "访问审批限制": {"仅boss账号可审批": "bool", "不允许申请访问": "bool"}
        },
        "tab_指定网页生效策略": [{"url_rule": "", "mode": "已限制|可访问", "behavior_controls": "仅mode=可访问时配置"}],
        "tab_所有网页通用策略": {"复制": "允许|允许且记录|限制且记录", "文件上传": "同上", "文件下载": "同上", "打印": "同上", "鼠标点击": "允许|限制", "键盘输入": "允许|限制", "查看密码框": "允许|限制"}
      },
      "output_rules": [
        "所有字段值直接可填入表单",
        "不输出平台表单中没有的字段",
        "不输出 audit_trail、compliance、approval_chain、temporary_access 等超出平台能力的内容"
      ],
      "next_phase": "phase_5_deliver"
    },

    "phase_5_deliver": {
      "description": "交付并同步RAG",
      "deliverables": [
        "表单填写版 JSON",
        "URL验证状态说明（如有RAG来源）"
      ],
      "rag_update": {
        "trigger": "对话中出现知识库没有的新页面描述或URL",
        "action": "将新URL条目写入RAG库，标注来源和验证状态"
      }
    }
  },

