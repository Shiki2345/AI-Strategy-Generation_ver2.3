{
  "policy_id": "amazon_us_account_approval_001",
  "policy_name": "运营专员访问美国站账户详情页审批策略",
  "policy_type": "approval_based_access_control",
  "description": "运营专员访问美国亚马逊 Seller Central 账户详情页需要实时审批，由 BOSS 决定临时访问权限的有效期",
  "version": "1.0",
  "created_at": "2024-01-15T10:30:00+08:00",
  
  "target_resources": {
    "page_name": "美国亚马逊账户详情页",
    "exact_url": "https://sellercentral.amazon.com/sw/AccountInfo/",
    "url_pattern": "sellercentral.amazon.com/sw/AccountInfo*",
    "match_type": "prefix",
    "marketplace": "US",
    "category": "account_management",
    "sensitivity_level": "high",
    "description": "包含账户设置、银行信息、税务信息、公司信息等敏感数据"
  },
  
  "time_restrictions": {
    "enabled": true,
    "schedule": {
      "mode": "always",
      "days_of_week": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
      "time_range": {
        "start": "00:00",
        "end": "23:59"
      },
      "timezone": "Asia/Shanghai",
      "description": "全天生效，7x24 小时"
    }
  },
  
  "access_control": {
    "default_action": "require_approval",
    "approval_workflow": {
      "enabled": true,
      "workflow_type": "real_time_approval",
      "approval_chain": [
        {
          "level": 1,
          "approver_role": "BOSS",
          "approver_description": "公司 BOSS/最高决策者",
          "approval_timeout": "30 minutes",
          "timeout_action": "auto_reject",
          "notification_channels": ["email", "sms", "app_push"]
        }
      ],
      "application_form": {
        "reason_required": false,
        "reason_description": "申请理由（可选填写）",
        "reason_max_length": 500,
        "additional_fields": [
          {
            "field_name": "urgency_level",
            "field_type": "select",
            "options": ["紧急", "普通", "不紧急"],
            "required": true
          },
          {
            "field_name": "estimated_duration",
            "field_type": "text",
            "description": "预计需要访问多久",
            "required": false
          }
        ]
      },
      "temporary_access": {
        "duration_controlled_by": "approver",
        "duration_options": [
          {"label": "15 分钟", "value": "15m"},
          {"label": "30 分钟", "value": "30m"},
          {"label": "1 小时", "value": "1h"},
          {"label": "2 小时", "value": "2h"},
          {"label": "4 小时", "value": "4h"},
          {"label": "当天有效", "value": "1d"},
          {"label": "自定义", "value": "custom"}
        ],
        "default_duration": "1h",
        "max_duration": "7d",
        "auto_revoke_on_expiry": true,
        "allow_extension": true,
        "extension_requires_new_approval": true
      }
    }
  },
  
  "user_scope": {
    "apply_to": {
      "roles": ["运营专员", "运营助理", "初级运营"],
      "description": "所有运营专员及相关职位"
    },
    "exceptions": {
      "roles": ["BOSS", "财务总监", "IT 管理员"],
      "users": [],
      "groups": ["高管组", "财务组"],
      "description": "BOSS、财务总监、IT 管理员不受此策略限制，可直接访问"
    }
  },
  
  "block_behavior": {
    "block_screen": {
      "enabled": true,
      "title": "🔒 需要审批才能访问",
      "message": "你正在尝试访问【美国站账户详情页】\n\n此页面包含敏感的账户和财务信息，运营专员需要获得 BOSS 批准后才能访问。",
      "show_page_info": true,
      "page_info": {
        "page_name": "美国亚马逊账户详情页",
        "url": "https://sellercentral.amazon.com/sw/AccountInfo/",
        "sensitivity": "高敏感度 - 包含银行、税务、公司信息"
      },
      "actions": [
        {
          "type": "primary",
          "label": "🚀 申请访问权限",
          "action": "open_approval_form"
        },
        {
          "type": "secondary",
          "label": "📋 查看我的申请记录",
          "action": "view_my_requests"
        },
        {
          "type": "tertiary",
          "label": "❌ 返回上一页",
          "action": "go_back"
        }
      ]
    },
    "approval_form_ui": {
      "title": "申请访问：美国站账户详情页",
      "fields": [
        {
          "id": "reason",
          "label": "申请理由（可选）",
          "type": "textarea",
          "placeholder": "例如：需要更新银行账户信息 / 配合财务审计 / 紧急处理账户问题",
          "required": false,
          "rows": 4
        },
        {
          "id": "urgency",
          "label": "紧急程度",
          "type": "radio",
          "options": [
            {"value": "urgent", "label": "🔴 紧急（15 分钟内需要）"},
            {"value": "normal", "label": "🟡 普通（1 小时内需要）"},
            {"value": "low", "label": "🟢 不紧急（今天内需要）"}
          ],
          "required": true,
          "default": "normal"
        },
        {
          "id": "estimated_time",
          "label": "预计操作时长",
          "type": "text",
          "placeholder": "例如：10 分钟",
          "required": false
        }
      ],
      "submit_button": "📤 提交审批申请",
      "cancel_button": "取消"
    },
    "approval_notification": {
      "to_approver": {
        "title": "【访问审批】运营专员申请访问账户详情页",
        "template": "员工 {{applicant_name}}（{{applicant_role}}）申请访问：\n\n📄 页面：美国站账户详情页\n🔗 URL：https://sellercentral.amazon.com/sw/AccountInfo/\n⏰ 申请时间：{{request_time}}\n🚨 紧急程度：{{urgency}}\n💬 申请理由：{{reason}}\n⏱️ 预计时长：{{estimated_time}}\n\n请在 30 分钟内处理，否则将自动拒绝。",
        "actions": [
          {"label": "✅ 批准", "action": "approve"},
          {"label": "❌ 拒绝", "action": "reject"}
        ]
      },
      "to_applicant_approved": {
        "title": "✅ 访问申请已批准",
        "template": "你的访问申请已获得 BOSS 批准！\n\n📄 页面：美国站账户详情页\n⏰ 批准时间：{{approval_time}}\n⌛ 有效期：{{duration}}\n⏳ 到期时间：{{expiry_time}}\n\n请在有效期内完成操作，到期后将自动失效。",
        "auto_redirect": true,
        "redirect_delay": 3
      },
      "to_applicant_rejected": {
        "title": "❌ 访问申请已拒绝",
        "template": "很抱歉，你的访问申请未获批准。\n\n📄 页面：美国站账户详情页\n⏰ 拒绝时间：{{rejection_time}}\n💬 拒绝原因：{{rejection_reason}}\n\n如有疑问，请联系 BOSS。"
      },
      "to_applicant_timeout": {
        "title": "⏱️ 访问申请已超时",
        "template": "你的访问申请在 30 分钟内未获得审批，已自动拒绝。\n\n如仍需访问，请重新提交申请。"
      }
    },
    "access_granted_reminder": {
      "show_banner": true,
      "banner_message": "⚠️ 你正在临时访问受限页面，权限将于 {{expiry_time}} 到期",
      "countdown_timer": true,
      "expire_soon_alert": {
        "enabled": true,
        "alert_before_minutes": 5,
        "message": "⏰ 你的临时访问权限将在 5 分钟后到期"
      }
    }
  },
  
  "enforcement": {
    "strict_mode": true,
    "bypass_allowed": false,
    "log_all_events": true,
    "log_retention_days": 90,
    "events_to_log": [
      "access_blocked",
      "approval_requested",
      "approval_granted",
      "approval_rejected",
      "approval_timeout",
      "temporary_access_started",
      "temporary_access_expired",
      "access_during_valid_period"
    ]
  },
  
  "audit_trail": {
    "enabled": true,
    "capture_details": {
      "applicant_info": ["user_id", "name", "role", "department", "email"],
      "request_details": ["timestamp", "reason", "urgency", "estimated_duration"],
      "approver_info": ["approver_id", "name", "role", "decision", "approved_duration"],
      "access_log": ["access_time", "session_duration", "actions_performed", "ip_address"]
    },
    "generate_reports": {
      "daily_summary": true,
      "weekly_report": true,
      "monthly_analytics": true,
      "report_recipients": ["BOSS", "IT 管理员", "合规专员"]
    }
  },
  
  "compliance": {
    "data_sensitivity": "high",
    "regulatory_requirements": [
      "内部财务信息保护",
      "账户信息访问审计",
      "最小权限原则"
    ],
    "risk_level": "high",
    "mitigation_strategy": "实时审批 + 时限访问 + 完整审计"
  },
  
  "metadata": {
    "created_by": "Amazon Access Policy Assistant",
    "created_by_tool": "RAG-powered Policy Generator",
    "last_modified": "2024-01-15T10:30:00+08:00",
